[Unit]
Description=MOODY Music Archive Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/moody/backend
ExecStart=/opt/moody/backend/server
Restart=always
RestartSec=5
Environment=MOODY_PORT=8080
Environment=MOODY_ADMIN_PORT=8082
Environment=MOODY_STORAGE_PATH=/opt/moody/storage

[Install]
WantedBy=multi-user.target
