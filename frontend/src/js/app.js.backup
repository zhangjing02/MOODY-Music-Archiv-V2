window.deleteAudioFromIndexedDB = deleteAudioFromIndexedDB;

// å°†æœ¬åœ°æ­Œæ›²æ˜ å°„ä¹Ÿå¯¼å‡ºåˆ°å…¨å±€ï¼Œæ–¹ä¾¿å…¶ä»–æ¨¡å—è®¿é—®
window.localSongsMap = localSongsMap;

